<!DOCTYPE html>
<html>
<head>
  <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; line-height: 1.6; color: #ffffff; background-color: #f4f4f4; margin: 0; padding: 0;">
  <div class="container" style="max-width: 600px; margin: 20px auto; padding: 30px; background-color: #1a1a1a; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.3);">
    <div class="content" style="padding: 20px 0;">
      <p style="color: #ffffff; margin-bottom: 15px;"><%= t('mailers.user_mailer.password_reset.greeting', name: @user.name || @user.email) %></p>
      <p style="color: #ffffff; margin-bottom: 15px;"><%= t('mailers.user_mailer.password_reset.intro') %></p>
      
      <div style="text-align: center; margin: 30px 0;">
        <a href="<%= @reset_url %>" class="button" style="display: inline-block; padding: 14px 28px; background-color: #007bff; color: #ffffff !important; text-decoration: none; border-radius: 6px; font-weight: bold;">
          <%= t('mailers.user_mailer.password_reset.button') %>
        </a>
      </div>
      
      <p style="color: #ffffff; margin-bottom: 15px;"><%= t('mailers.user_mailer.password_reset.expiry') %></p>
      <p style="color: #ffffff; margin-bottom: 15px;"><%= t('mailers.user_mailer.password_reset.ignore') %></p>
    </div>
    
    <div class="footer" style="font-size: 12px; color: #aaaaaa; margin-top: 40px; border-top: 1px solid #333; padding-top: 20px; text-align: center;">
      <p style="color: #aaaaaa; margin: 0;"><%= t('mailers.user_mailer.password_reset.team') %></p>
    </div>
  </div>
</body>
</html>

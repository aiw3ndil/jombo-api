<h1><%= t('mailers.user_mailer.booking_received.subject') %></h1>

<p><%= t('mailers.user_mailer.booking_received.greeting', name: @driver.name) %></p>

<p><%= t('mailers.user_mailer.booking_received.intro') %></p>

<%= render layout: 'card' do %>
  <h3 style="margin-top: 0; color: #FFFFFF;"><%= t('mailers.user_mailer.booking_received.your_trip') %></h3>
  <p><strong><%= t('mailers.user_mailer.booking_received.origin') %></strong> <%= @trip.departure_location %></p>
  <p><strong><%= t('mailers.user_mailer.booking_received.destination') %></strong> <%= @trip.arrival_location %></p>
  <p><strong><%= t('mailers.user_mailer.booking_received.datetime') %></strong> <%= l(@trip.departure_time, format: :email) %></p>
<% end %>

<h3><%= t('mailers.user_mailer.booking_received.request_from', passenger_name: @passenger.name) %></h3>
<%= render layout: 'card' do %>
  <p><strong><%= t('mailers.user_mailer.booking_received.seats_requested') %></strong> <%= @booking.seats %></p>
  <p><strong><%= t('mailers.user_mailer.booking_received.status') %></strong> <strong style="color: #0BB1D3;"><%= t('mailers.user_mailer.booking_received.status_pending') %></strong></p>
<% end %>

<div style="text-align: center; margin: 32px 0;">
  <%= render 'button', url: "#{@frontend_url}/my-trips/#{@trip.id}", text: t('mailers.user_mailer.booking_received.button') %>
</div>

<p><strong><%= t('mailers.user_mailer.booking_received.actions_title') %></strong></p>
<p>
  • <%= t('mailers.user_mailer.booking_received.action_confirm') %><br>
  • <%= t('mailers.user_mailer.booking_received.action_reject') %>
</p>

<p><%= t('mailers.user_mailer.booking_received.reminder') %></p>

<p><strong><%= t('mailers.user_mailer.booking_received.team') %></strong></p>

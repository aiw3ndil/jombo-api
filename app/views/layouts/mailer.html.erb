<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
      /* Brand Colors */
      :root {
        --brand-dark: #120D2B;
        --brand-cyan: #0BB1D3;
        --brand-purple: #9F2FFF;
        --brand-blue: #5471E9;
        --brand-pink: #FF419C;
        --white: #FFFFFF;
        --card-bg: #1A1535;
        --card-border: #2D284D;
      }

      body {
        font-family: 'Geist Sans', 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.6;
        color: #FFFFFF;
        background-color: #120D2B;
        margin: 0;
        padding: 0;
        -webkit-font-smoothing: antialiased;
      }

      .email-wrapper {
        background-color: #120D2B;
        padding: 20px 0;
      }

      .email-container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #120D2B;
        overflow: hidden;
      }

      .email-header {
        padding: 40px 20px;
        text-align: center;
        border-top: 4px solid #0BB1D3;
      }

      .email-logo {
        font-size: 24px;
        font-weight: 800;
        color: #FFFFFF;
        margin: 0;
        letter-spacing: 2px;
        text-transform: uppercase;
      }

      .email-body {
        padding: 20px;
      }

      .email-footer {
        padding: 40px 20px;
        text-align: center;
        font-size: 14px;
        color: #717285;
        border-top: 1px solid #2D284D;
      }

      .email-footer a {
        color: #0BB1D3;
        text-decoration: none;
      }

      h1 {
        font-size: 24px;
        font-weight: 700;
        color: #FFFFFF;
        margin-bottom: 20px;
      }

      h2 {
        font-size: 20px;
        font-weight: 600;
        color: #FFFFFF;
        margin-top: 24px;
        margin-bottom: 16px;
      }

      p {
        font-size: 16px;
        margin: 16px 0;
        color: #d1d1e0;
      }

      .cta-button {
        display: inline-block;
        padding: 14px 32px;
        background: linear-gradient(89.8deg, #0BB1D3 0%, #9F2FFF 100%);
        color: #FFFFFF !important;
        text-decoration: none;
        border-radius: 50px;
        font-weight: 700;
        font-size: 16px;
        text-align: center;
        min-height: 44px;
        line-height: 44px;
        padding-top: 0;
        padding-bottom: 0;
      }

      .card {
        background-color: #1A1535;
        border: 1px solid #2D284D;
        border-radius: 12px;
        padding: 24px;
        margin: 24px 0;
      }

      .small {
        font-size: 14px;
        color: #717285;
      }

      @media (prefers-color-scheme: dark) {
        body, .email-wrapper, .email-container {
          background-color: #120D2B !important;
        }
        .email-logo, h1, h2, strong {
          color: #FFFFFF !important;
        }
        p {
          color: #d1d1e0 !important;
        }
      }

      @media only screen and (max-width: 600px) {
        .email-container {
          width: 100% !important;
        }
        .email-body {
          padding: 20px 15px !important;
        }
      }
    </style>
  </head>

  <body>
    <div class="email-wrapper">
      <div class="email-container">
        <div class="email-header">
          <div class="email-logo">JOMBO</div>
        </div>
        
        <div class="email-body">
          <%= yield %>
        </div>
        
        <div class="email-footer">
          <p>© <%= Time.current.year %> Jombo. <%= t('layouts.mailer.all_rights_reserved', default: 'Todos los derechos reservados.') %></p>
          <p>
            <%= t('layouts.mailer.platform_description', default: 'Tu viaje compartido, sin comisiones.') %><br>
            <a href="#"><%= t('layouts.mailer.terms', default: 'Términos') %></a> | 
            <a href="#"><%= t('layouts.mailer.privacy', default: 'Privacidad') %></a> | 
            <a href="#"><%= t('layouts.mailer.contact', default: 'Contacto') %></a>
          </p>
          <% if @user || @driver || @recipient %>
            <p class="small">
              <%= t('layouts.mailer.unsubscribe', default: 'Si no deseas recibir más correos, puedes') %> 
              <a href="#"><%= t('layouts.mailer.unsubscribe_link', default: 'darte de baja aquí') %></a>.
            </p>
          <% end %>
        </div>
      </div>
    </div>
  </body>
</html>
